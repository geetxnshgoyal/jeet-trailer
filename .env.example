# ─────────────────────────────────────────────────────────────
# Jeet Trailers — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Firebase Web SDK (client) ────────────────────────────────
# Firebase Console → Project settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server only — never expose) ──────────
# Firebase Console → Project settings → Service accounts → Generate new private key
# Paste the values from the downloaded JSON. The private key must keep its
# literal "\n" escapes on a single line (they are converted at runtime).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Emulator (local development without a real project) ──────
# Set to "true" to point the app at the Firebase Emulator Suite.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# ── App session ──────────────────────────────────────────────
SESSION_COOKIE_NAME=jt_session

# ── Storage provider ─────────────────────────────────────────
# "firebase" (default). Abstraction allows "s3" / "cloudinary" later.
STORAGE_PROVIDER=firebase
